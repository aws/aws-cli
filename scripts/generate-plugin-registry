#!/usr/bin/env python
"""Generate the lazy plugin registry for AWS CLI v2.

This script is the authoritative source of truth for which customizations
exist and in what order they are registered. It mirrors what the old
monolithic awscli_initialize used to do, but instead of actually importing
and calling each initialize function, it runs each registration call against a
_MiniEmitter that captures (event_pattern, module, fn_name, type) tuples
without side effects.

The output is written to a handlers_registry.py file as a plain Python dict
PLUGIN_REGISTRY mapping each event pattern to a list of entries:

  (module, fn_name, 'init')    call fn(event_handlers)
  (module, fn_name, 'direct')  event_handlers.register(event_pattern, fn)

At runtime, the LazyInitEmitter triggers entries on demand: before emitting
event X, it finds entries whose event patterns match X, dispatches each
entry at most once, then proceeds with normal event dispatch.

Usage:
    generate-plugin-registry --repo-root /path/to/aws-cli
    generate-plugin-registry --check --repo-root /path/to/aws-cli
    generate-plugin-registry --print

The --repo-root flag specifies the AWS CLI v2 repository root. The script
adds it to sys.path to import awscli, and writes the generated registry to
<repo-root>/awscli/handlers_registry.py.

Run this script whenever a customization is added, removed, or changed, and
commit the updated registry in the AWS CLI v2 GitHub repository.

To add a new customization:
  1. Add a call to _register() or _register_direct() in _all_registrations()
     below, in the same position it would appear in awscli_initialize.
  2. Re-run this script with --output pointing to the AWS CLI v2 repo.
  3. Commit the updated handlers_registry.py in the AWS CLI v2 repo.
"""
import argparse
import collections
import difflib
import importlib
import os
import sys


class _Entry:
    """A single pending registration."""
    __slots__ = ('module', 'fn_name', 'event_name')

    def __init__(self, module, fn_name, event_name=None):
        self.module = module
        self.fn_name = fn_name
        # None means "call fn(event_handlers)"
        self.event_name = event_name


class _Recorder:
    """Collects registration calls without importing any modules."""

    def __init__(self):
        self._entries = []

    def register_fn(self, module, fn_name):
        """Record a call of the form fn(event_handlers)."""
        self._entries.append(_Entry(module, fn_name))

    def register_direct(self, module, fn_name, event_name):
        """Record a call of the form event_handlers.register(event_name, fn)."""
        self._entries.append(_Entry(module, fn_name, event_name))

    @property
    def entries(self):
        return list(self._entries)


class _MiniEmitter:
    """Minimal emitter that just records event names."""

    def __init__(self):
        self.registrations = []

    def register(self, event_name, *args, **kwargs):
        self.registrations.append(event_name)

    register_first = register
    register_last = register

    def emit(self, *a, **k): pass
    def emit_first_non_none_response(self, *a, **k): return None


def _all_registrations(r):
    """The authoritative list of all plugin registrations.

    This is the source of truth — update this when adding/removing
    customizations.

    r.register_fn(module, fn_name)
        -- will call fn(event_handlers) at runtime

    r.register_direct(module, fn_name, event_name)
        -- will call event_handlers.register(event_name, fn) at runtime
    """
    r.register_direct('awscli.paramfile', 'register_uri_param_handler', 'session-initialized')
    r.register_direct('awscli.customizations.binaryformat', 'add_binary_formatter', 'session-initialized')
