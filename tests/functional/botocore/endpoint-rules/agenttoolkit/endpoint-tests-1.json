{
    "version": "1",
    "testCases": [
        {
            "documentation": "Returns regional endpoint for us-east-1",
            "expect": {
                "endpoint": {
                    "url": "https://agent-toolkit.us-east-1.api.aws"
                }
            },
            "params": {
                "Region": "us-east-1"
            }
        },
        {
            "documentation": "Returns regional endpoint for us-west-2",
            "expect": {
                "endpoint": {
                    "url": "https://agent-toolkit.us-west-2.api.aws"
                }
            },
            "params": {
                "Region": "us-west-2"
            }
        },
        {
            "documentation": "Overrides endpoint",
            "expect": {
                "endpoint": {
                    "url": "https://override.agent-toolkit.api.aws"
                }
            },
            "params": {
                "Region": "us-east-1",
                "Endpoint": "https://override.agent-toolkit.api.aws"
            }
        }
    ]
}