{
    "version": "1",
    "testCases": [
        {
            "documentation": "Returns endpoint for us-east-1",
            "expect": {
                "endpoint": {
                    "url": "https://agent-toolkit.us-east-1.api.aws"
                }
            },
            "params": {
                "Region": "us-east-1"
            }
        },
        {
            "documentation": "Returns error for us-west-2",
            "expect": {
                "error": "AgentToolkit is only available in us-east-1"
            },
            "params": {
                "Region": "us-west-2"
            }
        },
        {
            "documentation": "Overrides endpoint regardless of region",
            "expect": {
                "endpoint": {
                    "url": "https://override.agent-toolkit.api.aws"
                }
            },
            "params": {
                "Region": "us-west-2",
                "Endpoint": "https://override.agent-toolkit.api.aws"
            }
        }
    ]
}