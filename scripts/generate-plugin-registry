def _build_registry(entries):
    """Map each entry to its event patterns, producing event_pattern -> [entries]."""
    registry = collections.OrderedDict()
    seen = set()

    def _add(event_pattern, entry_tuple):
        key = (event_pattern,) + entry_tuple
        if key not in seen:
            seen.add(key)
            registry.setdefault(event_pattern, []).append(entry_tuple)

    for entry in entries:
        if entry.event_name is not None:
            # Direct registration — event pattern is explicit.
            entry_tuple = (entry.module, entry.fn_name, 'direct')
            _add(entry.event_name, entry_tuple)
        else:
            # register_fn — run against _MiniEmitter to discover events.
            mini = _MiniEmitter()
            mod = importlib.import_module(entry.module)
            fn = getattr(mod, entry.fn_name)
            fn(mini)

            entry_tuple = (entry.module, entry.fn_name, 'init')
            if not mini.registrations:
                # No events recorded — should not happen, but be safe.
                _add('session-initialized', entry_tuple)
            else:
                for event_name in mini.registrations:
                    _add(event_name, entry_tuple)

    # Sort by event pattern for stable output.
    return collections.OrderedDict(
        sorted(registry.items(), key=lambda kv: kv[0])
    )


class _MainCallbackEmitter:
    """Emitter that captures only building-command-table.main callbacks."""

    def __init__(self):
        self.main_callbacks = []

    def register(self, event_name, handler, *args, **kwargs):
        if event_name == 'building-command-table.main':
            self.main_callbacks.append(handler)

    register_first = register
    register_last = register


def _probe_main_command_table_ops(registry):
    """Probe plugins that register against building-command-table.main.

    Builds a real command table (service names from botocore), fires each
    plugin's callbacks in order, and diffs the table after each callback
    to detect renames and additions.  Returns an ordered list of:

      ('rename', old_name, new_name, module, fn_name)
      ('add', cmd_name, cmd_module, cmd_class, module, fn_name)

    where module/fn_name identify the plugin that produced the operation.
    """
    import botocore.session

    session = botocore.session.Session()
    services = session.get_available_services()

    # Build a command table with lightweight placeholders.
    # We only need to track identity (id) and the .name attribute.
    class _Placeholder:
        def __init__(self, name):
            self.name = name

    command_table = collections.OrderedDict()
    for svc in services:
        command_table[svc] = _Placeholder(svc)

    main_entries = registry.get('building-command-table.main', [])
    ops = []

    for entry_module, entry_fn_name, entry_type in main_entries:
        # Discover which callbacks this plugin registers for
        # building-command-table.main.
        emitter = _MainCallbackEmitter()
        mod = importlib.import_module(entry_module)
        fn = getattr(mod, entry_fn_name)
        fn(emitter)

        for callback in emitter.main_callbacks:
            # Snapshot: map object id -> key before the callback fires.
            snap_id_to_key = {id(v): k for k, v in command_table.items()}

            callback(command_table=command_table, session=session)

            # Detect renames: same object id now under a different key.
            new_id_to_key = {id(v): k for k, v in command_table.items()}
            for obj_id, new_key in new_id_to_key.items():
                old_key = snap_id_to_key.get(obj_id)
                if old_key is not None and old_key != new_key:
                    ops.append((
                        'rename', old_key, new_key,
                        entry_module, entry_fn_name,
                    ))

            # Detect additions: object id was not in the previous snapshot.
            old_ids = set(snap_id_to_key.keys())
            for key, cmd in command_table.items():
                if id(cmd) not in old_ids:
                    cmd_module = type(cmd).__module__
                    cmd_class = type(cmd).__qualname__
                    ops.append((
                        'add', key, cmd_module, cmd_class,
                        entry_module, entry_fn_name,
                    ))

    return ops


def _render_registry(registry, main_ops):
    lines = [
        '# Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.',
        '#',
        '# Licensed under the Apache License, Version 2.0 (the "License"). You',
        '# may not use this file except in compliance with the License. A copy of',
        '# the License is located at',
        '#',
        '#     http://aws.amazon.com/apache2.0/',
        '#',
        '# or in the "license" file accompanying this file. This file is',
        '# distributed on an "AS IS" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF',
        '# ANY KIND, either express or implied. See the License for the specific',
        '# language governing permissions and limitations under the License.',
        '"""Maps event patterns to initializer entries.',
        '',
        'At runtime, the LazyInitEmitter triggers entries on demand:',
        'before emitting event X, it finds entries whose event patterns',
        'match X, dispatches each entry at most once, then proceeds',
        'with normal event dispatch.',
        '',
        'Entry formats:',
        "   (module, fn_name, 'init')    call fn(event_handlers)",
        "   (module, fn_name, 'direct')  event_handlers.register(event_pattern, fn)",
        '"""',
        'PLUGIN_REGISTRY = {',
    ]

    items = list(registry.items())
    for i, (event_pattern, entries) in enumerate(items):
        is_last = (i == len(items) - 1)
        lines.append(f'    {event_pattern!r}: [')
        for j, entry in enumerate(entries):
            comma = '' if j == len(entries) - 1 else ','
            lines.append(f'        {entry!r}{comma}')
        lines.append(f'    ]{("" if is_last else ",")}')

    lines.append('}')
    lines.append('')

    # Render MAIN_COMMAND_TABLE_OPS — the probed operations for
    # building-command-table.main plugins.  At runtime these replace
    # the building-command-table.main entries in PLUGIN_REGISTRY:
    # renames are applied directly and additions use LazyCommand.
    #
    # Entry formats:
    #   ('rename', old_name, new_name, module, fn_name)
    #   ('add', cmd_name, cmd_module, cmd_class, module, fn_name)
    lines.append('# Declarative model of changes made to the command table by plugins')
    lines.append('# that register against building-command-table.main.')
    lines.append('#')
    lines.append('# At runtime, plugins listed in building-command-table.main above')
    lines.append('# that only add or rename commands are handled via these pre-computed')
    lines.append('# operations instead of being imported when building-command-table.main')
    lines.append('# is emitted. This allows added commands to be wrapped in LazyCommand,')
    lines.append('# deferring the heavy module import until the command is actually invoked.')
    lines.append('#')
    lines.append("# Entry formats:")
    lines.append("#   ('rename', old_name, new_name, module, fn_name)")
    lines.append("#   ('add', cmd_name, cmd_module, cmd_class, module, fn_name)")
    lines.append('')
    lines.append('MAIN_COMMAND_TABLE_OPS = [')
    for op in main_ops:
        lines.append(f'    {op!r},')
    lines.append(']')
    lines.append('')
    return '\n'.join(lines)


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        '--repo-root',
        help='Root of the AWS CLI v2 repository (e.g. /path/to/aws-cli).',
    )
    parser.add_argument(
        '--check',
        action='store_true',
        help=(
            'Check that the registry at <repo-root>/awscli/handlers_registry.py '
            'matches a fresh generation. Exits with code 1 if they differ.'
        ),
    )
    parser.add_argument(
        '--print',
        dest='print_only',
        action='store_true',
        help='Print the generated registry to stdout instead of writing a file.',
    )
    args = parser.parse_args()

    if not args.print_only and not args.repo_root:
        parser.error('--repo-root is required unless --print is specified')

    output_path = None
    if args.repo_root:
        repo_root: str = os.path.abspath(args.repo_root)
        sys.path.insert(0, repo_root)
        output_path = os.path.join(repo_root, 'awscli', 'handlers_registry.py')

    recorder = _Recorder()
    _all_registrations(recorder)
    registry = _build_registry(recorder.entries)
    main_ops = _probe_main_command_table_ops(registry)
    source = _render_registry(registry, main_ops)

    if args.print_only:
        print(source)
        return

    if output_path is None:
        parser.error('--repo-root is required unless --print is specified')
    output_path: str  # type checker: parser.error() never returns

    if args.check:
        if not os.path.exists(output_path):
            print(
                f'ERROR: {output_path} does not exist. '
                'Run without --check to generate it.',
                file=sys.stderr,
            )
            sys.exit(1)
        with open(output_path) as f:
            committed = f.read()
        if committed == source:
            print('OK: committed registry matches fresh generation.')
        else:
            diff = difflib.unified_diff(
                committed.splitlines(keepends=True),
                source.splitlines(keepends=True),
                fromfile=f'{output_path} (committed)',
                tofile=f'{output_path} (generated)',
            )
            sys.stderr.write(''.join(diff))
            print(
                f'ERROR: {output_path} is out of date.\n'
                'Run `generate-plugin-registry` and commit the result.',
                file=sys.stderr,
            )
            sys.exit(1)
        return

    with open(output_path, 'w') as f:
        f.write(source)
    print(f'Written {output_path}')

    total = sum(len(v) for v in registry.values())
    unique = len({e for entries in registry.values() for e in entries})
    print(f'\nRegistry summary:')
    print(f'  {len(registry)} event patterns, {total} total entries, {unique} unique initializers')


if __name__ == '__main__':
    main()
