    r.register_fn('awscli.customizations.removals', 'register_removals')
    r.register_fn('awscli.customizations.rds', 'register_rds_modify_split')
    r.register_fn('awscli.customizations.rekognition', 'register_rekognition_detect_labels')
    r.register_fn('awscli.customizations.rds', 'register_add_generate_db_auth_token')
    r.register_fn('awscli.customizations.dsql', 'register_dsql_customizations')
